  "item": [
    {
      "name": "1. Auth & Users",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login Successful\", function () { pm.response.to.have.status(200); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) { pm.collectionVariables.set(\"authToken\", jsonData.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login"
            }
          }
        },
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"User Created\", function () { pm.response.to.have.status(201); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set(\"recordId\", jsonData.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"staff@etihad.com\",\n  \"password\": \"staff123\",\n  \"name\": \"Staff Member\",\n  \"role\": \"content-editor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users"
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Staff Member (Updated)\"\n}"
            },
            "url": {
